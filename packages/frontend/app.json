{
  "expo": {
    "name": "Training Grounds",
    "slug": "training-grounds",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/icon.png",
    "scheme": "traininggrounds",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./app/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E1E1E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.traininggrounds.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Training Grounds uses your camera to scan QR codes for class check-in.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./app/assets/adaptive-icon.png",
        "backgroundColor": "#1E1E1E"
      },
      "package": "com.traininggrounds.app",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-camera",
      "expo-notifications",
      "expo-secure-store",
      "expo-apple-authentication"
    ]
  }
}
